function grpHTML(g) {
  var st=calcStandings(g);
  var played=g.matches.filter(function(m){return m.s1!==null;}).length;
  var rows=st.map(function(t,i){
    // Mathematical qualification: can't be caught by team below
    var maxBelow=0;
    if(i<2){
      for(var j=i+1;j<st.length;j++){
        var maxPts=st[j].pts+3*(3-st[j].p);
        if(maxPts>maxBelow)maxBelow=maxPts;
      }
    }
    var confirmed=(i<2&&t.pts>maxBelow)?' confirmed':'';
    // Mathematical elimination: can't catch team above even with all wins
    var maxPossible=t.pts+3*(3-t.p);
    var eliminated=(maxPossible<st[1].pts)?' eliminated':'';
    var qc=(i===0?'q1':i===1?'q2':i===2?'q3':'')+confirmed+eliminated;
    var gd=t.gd>=0?'+'+t.gd:t.gd;
    return '<tr class="'+qc+'"><td><div class="tn"><span class="fl">'+fl(t.name)+'</span>'+sn(t.name)+'</div></td>'
      +'<td class="pts-c">'+t.pts+'</td><td class="num-c">'+t.p+'</td>'
      +'<td class="num-c">'+gd+'</td><td class="num-c">'+t.gf+':'+t.ga+'</td></tr>';
  }).join('');
  var mrows=g.matches.map(function(m){
    var sc=m.s1!==null
      ?'<span class="mscore">'+m.s1+'&ndash;'+m.s2+'</span>'
      :'<span class="mscore tbd">vs</span>';
    return '<div class="mrow"><span class="md">'+m.d+'</span>'
      +'<span class="mt1">'+fl(m.t1)+' '+sn(m.t1)+'</span>'+sc
      +'<span class="mt2">'+sn(m.t2)+' '+fl(m.t2)+'</span></div>';
  }).join('');
  return '<div class="grp"><div class="grp-hdr '+g.hc+'">GROUP '+g.id+'<small>'+played+'/6</small></div>'
    +'<table class="grp-tbl"><thead><tr><th>Team</th><th>Pts</th><th>P</th><th>GD</th><th>GF:GA</th></tr></thead>'
    +'<tbody>'+rows+'</tbody></table>'+mrows+'</div>';
}

function mcHTML(m) {
  var t1=m.t1||'', t2=m.t2||'';
  var k1=!!FLAGS[t1], k2=!!FLAGS[t2];
  var f1=k1?'<span class="mf">'+fl(t1)+'</span>':'';
  var f2=k2?'<span class="mf">'+fl(t2)+'</span>':'';
  var hasScore=m.s1!==null&&m.s2!==null;
  var win1=hasScore&&m.s1>m.s2, win2=hasScore&&m.s2>m.s1;
  var sc1=hasScore?'<span class="sc done">'+m.s1+'</span>':'<span class="sc">-</span>';
  var sc2=hasScore?'<span class="sc done">'+m.s2+'</span>':'<span class="sc">-</span>';
