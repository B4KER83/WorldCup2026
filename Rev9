function getWinner(m) {
  if (!m || m.s1===null || m.s2===null || !m.t1 || !m.t2) return null;
  if (m.s1 > m.s2) return m.t1;
  if (m.s2 > m.s1) return m.t2;
  return null;
}
function getLoser(m) {
  if (!m || m.s1===null || m.s2===null || !m.t1 || !m.t2) return null;
  if (m.s1 > m.s2) return m.t2;
  if (m.s2 > m.s1) return m.t1;
  return null;
}

// API wins — propagation only fills gaps
function propagateBracket() {
  for (var i=0; i<8; i++) {
    var wa=getWinner(KO.r32[i*2]), wb=getWinner(KO.r32[i*2+1]);
    if (wa && !KO.r16[i].t1) KO.r16[i].t1=wa;
    if (wb && !KO.r16[i].t2) KO.r16[i].t2=wb;
  }
  for (var i=0; i<4; i++) {
    var wa=getWinner(KO.r16[i*2]), wb=getWinner(KO.r16[i*2+1]);
    if (wa && !KO.qf[i].t1) KO.qf[i].t1=wa;
    if (wb && !KO.qf[i].t2) KO.qf[i].t2=wb;
  }
  for (var i=0; i<2; i++) {
    var wa=getWinner(KO.qf[i*2]), wb=getWinner(KO.qf[i*2+1]);
    if (wa && !KO.sf[i].t1) KO.sf[i].t1=wa;
    if (wb && !KO.sf[i].t2) KO.sf[i].t2=wb;
  }
  var sf1w=getWinner(KO.sf[0]), sf1l=getLoser(KO.sf[0]);
  var sf2w=getWinner(KO.sf[1]), sf2l=getLoser(KO.sf[1]);
  if (sf1w && !KO.final.t1) KO.final.t1=sf1w;
  if (sf2w && !KO.final.t2) KO.final.t2=sf2w;
  if (sf1l && !KO.third.t1) KO.third.t1=sf1l;
  if (sf2l && !KO.third.t2) KO.third.t2=sf2l;
}

