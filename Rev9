function calcStandings(g) {
  var s={};
  g.teams.forEach(function(t){s[t]={p:0,w:0,d:0,l:0,gf:0,ga:0,gd:0,pts:0};});
  g.matches.forEach(function(m){
    if(m.s1===null)return;
    var a=s[m.t1],b=s[m.t2];
    a.p++;b.p++;a.gf+=m.s1;a.ga+=m.s2;a.gd=a.gf-a.ga;
    b.gf+=m.s2;b.ga+=m.s1;b.gd=b.gf-b.ga;
    if(m.s1>m.s2){a.w++;a.pts+=3;b.l++;}
    else if(m.s1<m.s2){b.w++;b.pts+=3;a.l++;}
    else{a.d++;a.pts++;b.d++;b.pts++;}
  });
  return Object.keys(s).map(function(n){return Object.assign({name:n},s[n]);})
    .sort(function(x,y){return(y.pts-x.pts)||(y.gd-x.gd)||(y.gf-x.gf);});
}
function getTopTwo(gid) {
  var g=GROUPS.filter(function(x){return x.id===gid;})[0];
  var st=calcStandings(g);
  return{w:st[0].name,ru:st[1].name,third:st[2]?st[2].name:'?'};
}
function getAllThirdsSorted() {
  var all=[];
  GROUPS.forEach(function(g){
    var st=calcStandings(g);
    if(st[2])all.push({name:st[2].name,pts:st[2].pts,gd:st[2].gd,gf:st[2].gf,gid:g.id});
  });
  return all.sort(function(a,b){return(b.pts-a.pts)||(b.gd-a.gd)||(b.gf-a.gf);});
}

