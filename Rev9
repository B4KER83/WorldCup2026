<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>WC2026</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: #0d1117;
  font-family: 'Arial Narrow', Arial, sans-serif;
  overflow-x: hidden; overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  user-select: none; -webkit-user-select: none;
}
.page-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}
.pg-head {
  background: linear-gradient(135deg,#0a1530,#1a3a8a,#0a1530);
  border-bottom: 2px solid #c8a84b;
  padding: 7px 8px 5px;
  position: sticky; top: 0; z-index: 99;
  display: flex; align-items: center; justify-content: space-between; gap: 6px;
  width: 100%;
}
.pg-head-text h1 { color: #c8a84b; font-size: 13px; font-weight: 900; letter-spacing: 2px; }
.pg-head-text p  { color: #7a9acc; font-size: 7.5px; letter-spacing: 1px; margin-top: 1px; }
.btn-group { display: flex; gap: 6px; flex-shrink: 0; }
.hbtn {
  border: none; border-radius: 7px;
  font-size: 11px; font-weight: 900; padding: 7px 11px; cursor: pointer;
  white-space: nowrap; -webkit-tap-highlight-color: transparent;
}
.hbtn:active { opacity: .7; }
.btn-auto   { background: #c8a84b; color: #000; }
.btn-manual { background: #21262d; color: #c8a84b; border: 1px solid #c8a84b !important; }

.sec {
  background: #161b22; color: #c8a84b;
  font-size: 8.5px; font-weight: 900; letter-spacing: 2px;
  text-transform: uppercase; text-align: center; padding: 5px 4px;
  border-top: 1px solid #21262d; border-bottom: 1px solid #21262d;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%;
}
.sec::before,.sec::after { content:''; flex:1; height:1px; background:linear-gradient(to right,transparent,#c8a84b44); }
.sec::after { background:linear-gradient(to left,transparent,#c8a84b44); }

.legend {
  display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  padding: 4px 6px; background: #0d1117;
  font-size: 7.5px; color: #6e7681; border-bottom: 1px solid #21262d;
  width: 100%;
}
.legend span { display: flex; align-items: center; gap: 3px; }
.ldot { width: 8px; height: 8px; border-radius: 2px; }

.content-section { width: 100%; max-width: 1600px; padding: 0 8px; }

.grp-band {
  display: flex; gap: 5px; padding: 6px 5px;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  background: #0d1117; scrollbar-width: none;
  justify-content: center; width: 100%;
}
.grp-band::-webkit-scrollbar { display: none; }

.grp { flex:0 0 auto; width:152px; border-radius:8px; overflow:hidden; background:#fff; box-shadow:0 2px 8px rgba(0,0,0,.4); }
.grp-hdr { color:#fff; font-weight:900; font-size:10.5px; padding:4px 7px; display:flex; justify-content:space-between; align-items:center; }
.grp-hdr small { font-weight:400; font-size:8px; opacity:.75; }
.grp-tbl { width:100%; border-collapse:collapse; }
.grp-tbl th { background:#e8e8e8; font-size:7.5px; padding:2px; text-align:center; color:#555; }
.grp-tbl td { padding:2px; border-bottom:1px solid #eee; vertical-align:middle; }
.grp-tbl tr:last-child td { border-bottom:none; }
.tn { display:flex; align-items:center; gap:2px; font-weight:700; white-space:nowrap; font-size:8.5px; }
.fl { font-size:11px; line-height:1; }
.pts-c { font-weight:900; text-align:center; font-size:9px; }
.num-c { text-align:center; color:#777; font-size:8px; }
.q1{background:#c6f6d5!important} .q2{background:#bee3f8!important} .q3{background:#fefcbf!important}
.q1.confirmed{background:#22c55e!important;color:#fff;font-weight:900}
.q2.confirmed{background:#3b82f6!important;color:#fff;font-weight:900}
.eliminated{background:#fee2e2!important;color:#991b1b;opacity:.7}
.mrow { display:flex; align-items:center; padding:1.5px 4px; border-bottom:1px solid #f0f0f0; background:#f9f9f9; }
.mrow:last-child{border-bottom:none}
.mrow .md  { color:#bbb; font-size:7px; min-width:26px; flex-shrink:0; }
.mrow .mt1 { flex:1; font-weight:600; font-size:7.5px; white-space:nowrap; overflow:hidden; }
.mrow .mt2 { flex:1; text-align:right; font-weight:600; font-size:7.5px; white-space:nowrap; overflow:hidden; }
.mscore { background:#1a1a2e; color:#fff; padding:0 3px; border-radius:3px; font-weight:900; font-size:8px; margin:0 2px; flex-shrink:0; }
.mscore.tbd { background:#ccc; color:#888; }

.ga-h{background:linear-gradient(135deg,#1a7a3c,#2d9e52)} .gb-h{background:linear-gradient(135deg,#c0392b,#e74c3c)}
.gc-h{background:linear-gradient(135deg,#1a3a7a,#2563eb)} .gd-h{background:linear-gradient(135deg,#6a2d82,#8b5cf6)}
.ge-h{background:linear-gradient(135deg,#b05a10,#d97706)} .gf-h{background:linear-gradient(135deg,#1a7a6a,#0d9488)}
.gg-h{background:linear-gradient(135deg,#7a1a1a,#991b1b)} .gh-h{background:linear-gradient(135deg,#5a6a10,#84cc16)}
.gi-h{background:linear-gradient(135deg,#0a4a6a,#0369a1)} .gj-h{background:linear-gradient(135deg,#4a1a6a,#7c3aed)}
.gk-h{background:linear-gradient(135deg,#1a4a2a,#166534)} .gl-h{background:linear-gradient(135deg,#4a1a1a,#7f1d1d)}

.ko-section { background:#0d1117; padding:0 5px 6px; width:100%; display:flex; flex-direction:column; align-items:center; }
.round-label { text-align:center; color:#c8a84b; font-size:8px; font-weight:900; letter-spacing:2px; text-transform:uppercase; padding:5px 0 3px; }
.ko-scroll { overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; padding-bottom:2px; display:flex; justify-content:center; width:100%; }
.ko-scroll::-webkit-scrollbar{display:none}
.ko-row { display:flex; gap:5px; min-width:max-content; padding:0 1px; }

.mc { width:122px; flex-shrink:0; border:1.5px solid #21262d; border-radius:7px; overflow:hidden; background:#161b22; }
.mc.projected { border-color:#c8a84b55; }
.mc .tr { display:flex; align-items:center; padding:3.5px 6px; border-bottom:1px solid #21262d; font-size:8.5px; font-weight:700; color:#e6edf3; white-space:nowrap; overflow:hidden; }
.mc .tr:last-of-type{border-bottom:none}
.mc .tr .mf { margin-right:3px; font-size:10px; }
.mc .tr .sc { margin-left:auto; background:#21262d; color:#8b949e; padding:1px 5px; border-radius:4px; font-size:8px; min-width:18px; text-align:center; flex-shrink:0; font-weight:900; }
.mc .tr .sc.done { background:#1f6feb; color:#fff; }
.mc .bi { background:#0d1117; font-size:7px; color:#6e7681; padding:2px 5px; text-align:center; }
.mc .proj-tag { background:#c8a84b22; color:#c8a84b; font-size:6.5px; text-align:center; padding:1px 4px; font-weight:700; }
.tbd-t { color:#6e7681!important; font-style:italic; }

.mc-final { width:148px; flex-shrink:0; border:2.5px solid #c8a84b; border-radius:9px; overflow:hidden; background:#0d1117; box-shadow:0 3px 12px rgba(200,168,75,.25); }
.mc-final .fh { background:linear-gradient(135deg,#b8960a,#f0c832,#b8960a); color:#000; text-align:center; font-weight:900; font-size:13px; padding:5px; letter-spacing:3px; }
.mc-final .tr { display:flex; align-items:center; padding:5px 8px; border-bottom:1px solid #21262d; font-size:10px; font-weight:900; color:#e6edf3; }
.mc-final .tr:last-of-type{border-bottom:none}
.mc-final .tr .sc { margin-left:auto; background:#21262d; color:#6e7681; padding:2px 6px; border-radius:4px; font-size:9px; min-width:20px; text-align:center; }
.mc-final .bi { background:#161b22; font-size:7.5px; color:#8b949e; padding:3px 6px; text-align:center; }

.mc-third { width:130px; flex-shrink:0; border:1.5px solid #6e7681; border-radius:8px; overflow:hidden; background:#0d1117; }
.mc-third .th { background:#30363d; color:#c9d1d9; text-align:center; font-weight:900; font-size:9px; padding:3px; }
.mc-third .tr { display:flex; align-items:center; padding:4px 7px; border-bottom:1px solid #21262d; font-size:9px; font-weight:700; color:#e6edf3; }
.mc-third .tr:last-of-type{border-bottom:none}
.mc-third .tr .sc { margin-left:auto; background:#21262d; color:#6e7681; padding:1px 5px; border-radius:4px; font-size:8px; min-width:18px; text-align:center; }
.mc-third .bi { background:#161b22; font-size:7px; color:#6e7681; padding:2px 5px; text-align:center; }
.finals-row { display:flex; gap:8px; justify-content:center; align-items:flex-start; padding:2px 4px; flex-wrap:wrap; }

.pg-foot { background:#0a0a1e; color:#c8a84b; text-align:center; font-size:10px; font-weight:900; padding:8px; letter-spacing:2px; border-top:2px solid #c8a84b; margin-top:4px; width:100%; }

/* DESKTOP */
@media (min-width: 768px) {
  .page-wrapper { padding: 0 20px; }
  .pg-head { margin: 0 -20px; padding-left: 28px; padding-right: 28px; }
  .legend { margin: 0 -20px; padding: 8px 12px; width: calc(100% + 40px); }
  .sec { margin: 0 -20px; width: calc(100% + 40px); font-size: 12px; padding: 8px; }
  .content-section { max-width: 1400px; padding: 0; }
  .pg-head-text h1 { font-size: 20px; letter-spacing: 3px; }
  .pg-head-text p  { font-size: 11px; }
  .hbtn { font-size: 14px; padding: 9px 18px; }
  .ldot { width: 12px; height: 12px; }
  .grp-band { gap: 8px; padding: 10px 12px; }
  .grp { width: 220px; }
  .grp-hdr { font-size: 14px; padding: 6px 10px; }
  .grp-hdr small { font-size: 11px; }
  .grp-tbl th { font-size: 11px; padding: 3px 4px; }
  .grp-tbl td { padding: 3px 4px; }
  .tn { font-size: 12px; gap: 4px; }
  .fl { font-size: 15px; }
  .pts-c { font-size: 13px; }
  .num-c { font-size: 11px; }
  .mrow { padding: 3px 6px; }
  .mrow .md  { font-size: 10px; min-width: 36px; }
  .mrow .mt1 { font-size: 11px; }
  .mrow .mt2 { font-size: 11px; }
  .mscore { font-size: 11px; padding: 1px 5px; border-radius: 4px; }
  .ko-section { padding: 0 12px 10px; }
  .round-label { font-size: 12px; padding: 8px 0 5px; letter-spacing: 3px; }
  .ko-row { gap: 8px; }
  .mc { width: 170px; border-radius: 9px; }
  .mc .tr { font-size: 12px; padding: 5px 8px; }
  .mc .tr .mf { font-size: 14px; margin-right: 4px; }
  .mc .tr .sc { font-size: 11px; min-width: 22px; padding: 2px 6px; }
  .mc .bi { font-size: 10px; padding: 3px 8px; }
  .mc .proj-tag { font-size: 9px; padding: 2px 6px; }
  .mc-final { width: 210px; border-radius: 12px; }
  .mc-final .fh { font-size: 18px; padding: 8px; letter-spacing: 4px; }
  .mc-final .tr { font-size: 14px; padding: 7px 12px; }
  .mc-final .tr .sc { font-size: 13px; min-width: 26px; padding: 3px 8px; }
  .mc-final .bi { font-size: 11px; padding: 4px 10px; }
  .mc-third { width: 185px; border-radius: 10px; }
  .mc-third .th { font-size: 13px; padding: 5px; }
  .mc-third .tr { font-size: 12px; padding: 5px 10px; }
  .mc-third .tr .sc { font-size: 11px; min-width: 22px; }
  .mc-third .bi { font-size: 10px; padding: 3px 8px; }
  .finals-row { gap: 14px; padding: 6px 8px; }
  .pg-foot { font-size: 14px; padding: 12px; letter-spacing: 3px; }
}
@media (min-width: 1200px) {
  .content-section { max-width: 1600px; }
  .grp { width: 260px; }
  .mc { width: 195px; }
  .mc-final { width: 240px; }
  .mc-third { width: 210px; }
}

/* MODAL */
.overlay { display:none; position:fixed; inset:0; z-index:200; background:rgba(0,0,0,.88); overflow-y:auto; -webkit-overflow-scrolling:touch; }
.overlay.open { display:block; }
.modal { background:#161b22; border:2px solid #c8a84b; border-radius:14px; margin:12px auto 24px; max-width:420px; width:94%; overflow:hidden; }
.modal-hdr { background:linear-gradient(135deg,#b8960a,#f0c832,#b8960a); color:#000; padding:11px 14px; display:flex; align-items:center; justify-content:space-between; }
.modal-hdr h2 { font-size:14px; font-weight:900; letter-spacing:1.5px; }
.modal-close { background:rgba(0,0,0,.18); border:none; color:#000; font-size:18px; width:30px; height:30px; border-radius:15px; cursor:pointer; font-weight:900; display:flex; align-items:center; justify-content:center; }
.modal-close:active { opacity:.7; }
.modal-note { background:#21262d; color:#8b949e; font-size:9px; padding:6px 14px; text-align:center; border-bottom:1px solid #30363d; }
.modal-match { display:flex; align-items:center; gap:5px; padding:6px 14px; border-bottom:1px solid #21262d; background:#161b22; }
.modal-match:last-child { border-bottom:none; }
.tm { flex:1; color:#e6edf3; font-weight:700; font-size:10px; white-space:nowrap; overflow:hidden; }
.tm.r { text-align:right; }
.sinp { width:34px; background:#21262d; border:1.5px solid #30363d; color:#e6edf3; font-size:14px; font-weight:900; text-align:center; border-radius:6px; padding:3px 2px; -webkit-appearance:none; }
.sinp:focus { outline:none; border-color:#c8a84b; background:#2d333b; }
.sdash { color:#6e7681; font-weight:900; font-size:13px; flex-shrink:0; }
.modal-footer { padding:14px; }
.save-btn { width:100%; background:linear-gradient(135deg,#b8960a,#f0c832,#b8960a); border:none; border-radius:10px; color:#000; font-size:14px; font-weight:900; padding:12px; cursor:pointer; letter-spacing:1px; }
.save-btn:active { opacity:.8; }
</style>
</head>
