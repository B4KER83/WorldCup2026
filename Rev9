  var ph=m.placeholder?'<div class="proj-tag" style="color:#6e7681">&#x2192; TBD</div>':'';
  var d1=t1?((!k1&&t1)?'tbd-t':''):'tbd-t';
  var d2=t2?((!k2&&t2)?'tbd-t':''):'tbd-t';
  var lbl1=t1?sn(t1):'?', lbl2=t2?sn(t2):'?';
  var s1=win1?' style="color:#22c55e;font-weight:900"':'';
  var s2=win2?' style="color:#22c55e;font-weight:900"':'';
  return '<div class="mc'+(m.projected?' projected':'')+'">'+proj+ph
    +'<div class="tr'+(d1?' '+d1:'')+'"'+s1+'>'+f1+lbl1+' '+sc1+'</div>'
    +'<div class="tr'+(d2?' '+d2:'')+'"'+s2+'>'+f2+lbl2+' '+sc2+'</div>'
    +'<div class="bi">'+m.info+'</div></div>';
}

function koBlock(label,matches){
  return '<div class="round-label">'+label+'</div>'
    +'<div class="ko-scroll"><div class="ko-row">'+matches.map(mcHTML).join('')+'</div></div>';
}

function finalRow() {
  function teamRow(team, score, fallback) {
    var hasTm=!!team, hasF=!!FLAGS[team];
    var lbl=hasTm?(hasF?fl(team)+' '+sn(team):sn(team)):fallback;
    var sc=score!==null?'<span class="sc done">'+score+'</span>':'<span class="sc">-</span>';
    return '<div class="tr'+(hasTm?'':' tbd-t')+'">'+lbl+' '+sc+'</div>';
  }
  return '<div class="round-label">FINAL &amp; THIRD PLACE</div>'
    +'<div class="finals-row">'
    +'<div class="mc-final"><div class="fh">&#x26BD; FINAL</div>'
    +teamRow(KO.final.t1,KO.final.s1,'SF Winner 1')
    +teamRow(KO.final.t2,KO.final.s2,'SF Winner 2')
    +'<div class="bi">19 Jul &middot; MetLife Stadium, NJ</div></div>'
    +'<div class="mc-third"><div class="th">&#x1F949; THIRD PLACE</div>'
    +teamRow(KO.third.t1,KO.third.s1,'SF Loser 1')
    +teamRow(KO.third.t2,KO.third.s2,'SF Loser 2')
    +'<div class="bi">18 Jul &middot; MetLife Stadium</div></div>'
    +'</div>';
}

function buildPage() {
  var r32=buildR32();
  document.getElementById('top-groups').innerHTML=GROUPS.slice(0,6).map(grpHTML).join('');
  document.getElementById('bot-groups').innerHTML=GROUPS.slice(6).map(grpHTML).join('');

  // Merge projected R32 with real API data
  var r32Display=r32.map(function(proj,i){
    var real=KO.r32[i];
    return{t1:real.t1||proj.t1,t2:real.t2||proj.t2,
           s1:real.s1,s2:real.s2,info:real.info||proj.info,projected:!real.t1};
  });

  // Sync back so propagation sees projected teams too
  r32Display.forEach(function(m,i){
    KO.r32[i].t1=m.t1; KO.r32[i].t2=m.t2;
    KO.r32[i].s1=m.s1; KO.r32[i].s2=m.s2;
  });

  // Propagate winners (API data always wins — gaps only)
  propagateBracket();

  var anyR32Proj=r32Display.some(function(m){return m.projected;});
  document.getElementById('ko').innerHTML=
    koBlock('ROUND OF 32 &middot; 1&ndash;8'+(anyR32Proj?' &#x26A1;':''),r32Display.slice(0,8))
    +koBlock('ROUND OF 32 &middot; 9&ndash;16'+(anyR32Proj?' &#x26A1;':''),r32Display.slice(8))
    +koBlock('ROUND OF 16',KO.r16.map(function(m,i){
      return m.t1?m:{t1:R16_LABELS[i][0],t2:R16_LABELS[i][1],s1:m.s1,s2:m.s2,info:m.info,placeholder:true};
    }))
    +koBlock('QUARTER FINALS',KO.qf.map(function(m,i){
      return m.t1?m:{t1:QF_LABELS[i][0],t2:QF_LABELS[i][1],s1:m.s1,s2:m.s2,info:m.info,placeholder:true};
    }))
    +koBlock('SEMI FINALS',KO.sf.map(function(m,i){
      return m.t1?m:{t1:SF_LABELS[i][0],t2:SF_LABELS[i][1],s1:m.s1,s2:m.s2,info:m.info,placeholder:true};
    }))
    +finalRow();
}

loadFromStorage();
buildPage();

// AUTO FETCH
function setAutoBtn(state,msg) {
  var btn=document.getElementById('auto-btn');
  if(!btn)return;
  btn.textContent=msg||(state==='loading'?'Fetching...':state==='ok'?'Updated!':state==='err'?'Failed':'⚡ Auto');
  btn.style.background=state==='loading'?'#555':state==='ok'?'#238636':state==='err'?'#c0392b':'#c8a84b';
  btn.style.color=state==='loading'?'#aaa':state==='ok'||state==='err'?'#fff':'#000';
  btn.disabled=state==='loading';
  if(state==='ok'||state==='err')setTimeout(function(){setAutoBtn('default');},3000);
}

function processKOMatch(m,home,away,s1,s2) {
  var arr=null;
  if(m.stage==='LAST_32'||m.stage==='ROUND_OF_32') arr=KO.r32;
  else if(m.stage==='ROUND_OF_16'||m.stage==='LAST_16') arr=KO.r16;
  else if(m.stage==='QUARTER_FINALS') arr=KO.qf;
  else if(m.stage==='SEMI_FINALS') arr=KO.sf;
  else if(m.stage==='FINAL'){KO.final.t1=home;KO.final.t2=away;KO.final.s1=s1;KO.final.s2=s2;return true;}
  else if(m.stage==='THIRD_PLACE'){KO.third.t1=home;KO.third.t2=away;KO.third.s1=s1;KO.third.s2=s2;return true;}
  if(!arr)return false;
  var empty=-1;
  for(var i=0;i<arr.length;i++){
    if((arr[i].t1===home&&arr[i].t2===away)||(arr[i].t1===away&&arr[i].t2===home)){
      arr[i].s1=arr[i].t1===home?s1:s2; arr[i].s2=arr[i].t1===home?s2:s1; return true;
    }
    if(arr[i].t1===null&&empty===-1)empty=i;
  }
  if(empty!==-1){arr[empty].t1=home;arr[empty].t2=away;arr[empty].s1=s1;arr[empty].s2=s2;return true;}
  return false;
}

function fetchLiveScores() {
  setAutoBtn('loading');
  fetch(WORKER_URL)
    .then(function(res){if(!res.ok)throw new Error('HTTP '+res.status);return res.json();})
    .then(function(data){
      if(!data.matches||!data.matches.length)throw new Error('No matches');
      var updated=0;
      data.matches.forEach(function(m){
        if(m.status!=='FINISHED')return;
        var home=TEAM_MAP[m.homeTeam.name]||m.homeTeam.name;
        var away=TEAM_MAP[m.awayTeam.name]||m.awayTeam.name;
        var s1=m.score.fullTime.home, s2=m.score.fullTime.away;
        if(s1===null||s2===null)return;
        if(m.stage==='GROUP_STAGE'){
          GROUPS.forEach(function(g){
            g.matches.forEach(function(gm){
              if((gm.t1===home&&gm.t2===away)||(gm.t1===away&&gm.t2===home)){
                var sw=gm.t1===away;
                var n1=sw?s2:s1, n2=sw?s1:s2;
                if(gm.s1!==n1||gm.s2!==n2){gm.s1=n1;gm.s2=n2;updated++;}
              }
            });
          });
        } else {
          if(processKOMatch(m,home,away,s1,s2))updated++;
        }
      });
      saveToStorage();
      buildPage();
      setAutoBtn('ok',updated+' updated');
    })
    .catch(function(e){
      console.error(e.message);
      setAutoBtn('err');
    });
}

// MANUAL MODAL
function openModal() {
  var pending=[];
  GROUPS.forEach(function(g){
    g.matches.forEach(function(m,mi){
      if(m.s1===null)pending.push({g:g,m:m,mi:mi,order:DATE_ORDER[m.d]||99});
    });
  });
  pending.sort(function(a,b){return a.order-b.order||a.g.id.localeCompare(b.g.id);});
  document.getElementById('modal-note').textContent=pending.length>0
    ?pending.length+' match'+(pending.length!==1?'es':'')+' to enter — in date order'
    :'All matches have scores entered';
  var html='',lastDate='';
  pending.forEach(function(item){
    var g=item.g,m=item.m,mi=item.mi;
    if(m.d!==lastDate){
      html+='<div style="background:#0d1117;color:#c8a84b;font-size:9px;font-weight:900;'
        +'letter-spacing:1.5px;padding:6px 14px;border-bottom:1px solid #21262d;'
        +'text-transform:uppercase;">'+m.d+'</div>';
      lastDate=m.d;
    }
    var id1='s_'+g.id+'_'+mi+'_1', id2='s_'+g.id+'_'+mi+'_2';
    html+='<div class="modal-match">'
      +'<span style="background:'+GRP_CLR[g.id]+';color:#fff;border-radius:3px;'
      +'padding:1px 4px;font-size:7px;font-weight:900;flex-shrink:0;">G'+g.id+'</span>'
      +'<span class="tm">'+fl(m.t1)+' '+sn(m.t1)+'</span>'
      +'<input class="sinp" type="number" min="0" max="30" id="'+id1+'" placeholder="-" inputmode="numeric">'
      +'<span class="sdash">-</span>'
      +'<input class="sinp" type="number" min="0" max="30" id="'+id2+'" placeholder="-" inputmode="numeric">'
      +'<span class="tm r">'+sn(m.t2)+' '+fl(m.t2)+'</span>'
      +'</div>';
  });
  if(!html)html='<div class="modal-match"><span style="color:#6e7681;text-align:center;width:100%;font-size:12px;padding:20px;">&#x2713; All scores entered!</span></div>';
  document.getElementById('modal-body').innerHTML=html;
  document.getElementById('overlay').classList.add('open');
}
function closeModal(){document.getElementById('overlay').classList.remove('open');}
function saveScores(){
  GROUPS.forEach(function(g){
    g.matches.forEach(function(m,mi){
      if(m.s1===null){
        var e1=document.getElementById('s_'+g.id+'_'+mi+'_1');
        var e2=document.getElementById('s_'+g.id+'_'+mi+'_2');
        if(e1&&e2&&e1.value!==''&&e2.value!==''){m.s1=parseInt(e1.value);m.s2=parseInt(e2.value);}
      }
    });
  });
  saveToStorage(); buildPage(); closeModal();
}
document.getElementById('overlay').addEventListener('click',function(e){if(e.target===this)closeModal();});

// PINCH TO ZOOM
var zoom=1,lastDist=null;
function applyZoom(){
  document.body.style.transform='scale('+zoom+')';
  document.body.style.transformOrigin='0 0';
  document.body.style.width=(100/zoom)+'%';
}
document.addEventListener('touchstart',function(e){
  if(e.touches.length===2)
    lastDist=Math.hypot(e.touches[1].clientX-e.touches[0].clientX,e.touches[1].clientY-e.touches[0].clientY);
},{passive:true});
document.addEventListener('touchmove',function(e){
  if(e.touches.length===2&&lastDist){
    var d=Math.hypot(e.touches[1].clientX-e.touches[0].clientX,e.touches[1].clientY-e.touches[0].clientY);
    zoom=Math.min(Math.max(zoom*(d/lastDist),0.5),5);
    applyZoom(); lastDist=d;
  }
},{passive:true});
document.addEventListener('touchend',function(e){if(e.touches.length<2)lastDist=null;},{passive:true});
var lastTap=0;
document.addEventListener('touchend',function(e){
  if(e.touches.length===0){
    var now=Date.now();
    if(now-lastTap<280){zoom=1;applyZoom();}
    lastTap=now;
  }
},{passive:true});
</script>
