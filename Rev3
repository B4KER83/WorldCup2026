// AUTO FETCH
function setAutoBtn(state) {
  var btn = document.getElementById('auto-btn');
  if (!btn) return;
  if (state === 'loading') {
    btn.textContent = 'Fetching...';
    btn.style.background = '#555'; btn.style.color = '#aaa'; btn.disabled = true;
  } else if (state === 'ok') {
    btn.textContent = 'Updated!';
    btn.style.background = '#238636'; btn.style.color = '#fff'; btn.disabled = false;
    setTimeout(function() { setAutoBtn('default'); }, 3000);
  } else if (state === 'err') {
    btn.textContent = 'Failed';
    btn.style.background = '#c0392b'; btn.style.color = '#fff'; btn.disabled = false;
    setTimeout(function() { setAutoBtn('default'); }, 3000);
  } else {
    btn.textContent = 'Auto';
    btn.style.background = '#c8a84b'; btn.style.color = '#000'; btn.disabled = false;
  }
}

function fetchLiveScores() {
  setAutoBtn('loading');
  fetch(WORKER_URL)
    .then(function(res) {
      if (!res.ok) throw new Error('Worker ' + res.status);
      return res.json();
    })
    .then(function(data) {
      if (!data.matches) throw new Error('No matches');
      var updated = 0;
      data.matches.forEach(function(m) {
        if (m.status !== 'FINISHED') return;
        var home = TEAM_MAP[m.homeTeam.name] || m.homeTeam.name;
        var away = TEAM_MAP[m.awayTeam.name] || m.awayTeam.name;
        var s1 = m.score.fullTime.home;
        var s2 = m.score.fullTime.away;
        if (s1 === null || s2 === null) return;
        GROUPS.forEach(function(g) {
          g.matches.forEach(function(gm) {
            if ((gm.t1===home && gm.t2===away) || (gm.t1===away && gm.t2===home)) {
              var sw = gm.t1===away;
              var n1 = sw ? s2 : s1;
              var n2 = sw ? s1 : s2;
              if (gm.s1!==n1 || gm.s2!==n2) { gm.s1=n1; gm.s2=n2; updated++; }
            }
          });
        });
      });
      saveToStorage();
      buildPage();
      setAutoBtn('ok');
    })
    .catch(function(e) {
      console.error('Auto fetch failed:', e.message);
      setAutoBtn('err');
    });
}

// MANUAL MODAL
function openModal() {
  var pending = [];
  GROUPS.forEach(function(g) {
    g.matches.forEach(function(m, mi) {
      if (m.s1 === null) {
        pending.push({g:g, m:m, mi:mi, order:DATE_ORDER[m.d]||99});
      }
    });
  });
  pending.sort(function(a,b) { return a.order-b.order || a.g.id.localeCompare(b.g.id); });

  document.getElementById('modal-note').textContent = pending.length > 0
    ? pending.length + ' match' + (pending.length!==1?'es':'') + ' to enter - in date order'
    : 'All matches have scores entered';

  var html = '';
  var lastDate = '';
  pending.forEach(function(item) {
    var g = item.g, m = item.m, mi = item.mi;
    if (m.d !== lastDate) {
      html += '<div style="background:#0d1117;color:#c8a84b;font-size:9px;font-weight:900;'
        +'letter-spacing:1.5px;padding:6px 14px;border-bottom:1px solid #21262d;'
        +'text-transform:uppercase;">'+m.d+'</div>';
      lastDate = m.d;
    }
    var id1 = 's_'+g.id+'_'+mi+'_1';
    var id2 = 's_'+g.id+'_'+mi+'_2';
    html += '<div class="modal-match">'
      +'<span style="background:'+GRP_CLR[g.id]+';color:#fff;border-radius:3px;'
      +'padding:1px 4px;font-size:7px;font-weight:900;flex-shrink:0;">G'+g.id+'</span>'
      +'<span class="tm">'+fl(m.t1)+' '+sn(m.t1)+'</span>'
      +'<input class="sinp" type="number" min="0" max="30" id="'+id1+'" placeholder="-" inputmode="numeric">'
      +'<span class="sdash">-</span>'
      +'<input class="sinp" type="number" min="0" max="30" id="'+id2+'" placeholder="-" inputmode="numeric">'
      +'<span class="tm r">'+sn(m.t2)+' '+fl(m.t2)+'</span>'
      +'</div>';
  });

  if (html === '') {
    html = '<div style="padding:24px;text-align:center;color:#8b949e;font-size:13px">All scores entered!</div>';
  }

  document.getElementById('modal-body').innerHTML = html;
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('overlay').classList.remove('open');
  document.body.style.overflow = '';
}

function saveScores() {
  GROUPS.forEach(function(g) {
    g.matches.forEach(function(m, mi) {
      var el1 = document.getElementById('s_'+g.id+'_'+mi+'_1');
      var el2 = document.getElementById('s_'+g.id+'_'+mi+'_2');
      if (!el1 || !el2) return;
      var v1 = el1.value.trim(), v2 = el2.value.trim();
      if (v1 !== '' && v2 !== '') {
        m.s1 = parseInt(v1);
        m.s2 = parseInt(v2);
      }
    });
  });
  saveToStorage();
  closeModal();
  buildPage();
}

document.getElementById('overlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// PINCH TO ZOOM
var zoom = 1, lastDist = null;
document.addEventListener('touchstart', function(e) {
  if (e.touches.length === 2) {
    lastDist = Math.hypot(
      e.touches[1].clientX - e.touches[0].clientX,
      e.touches[1].clientY - e.touches[0].clientY
    );
  }
}, {passive:true});
document.addEventListener('touchmove', function(e) {
  if (e.touches.length === 2 && lastDist) {
    var d = Math.hypot(
      e.touches[1].clientX - e.touches[0].clientX,
      e.touches[1].clientY - e.touches[0].clientY
    );
    zoom = Math.min(Math.max(zoom * (d/lastDist), 0.5), 4);
    document.body.style.zoom = zoom;
    lastDist = d;
  }
}, {passive:true});
document.addEventListener('touchend', function(e) {
  if (e.touches.length < 2) lastDist = null;
}, {passive:true});
var lastTap = 0;
document.addEventListener('touchend', function(e) {
  if (e.touches.length === 0) {
    var now = Date.now();
    if (now - lastTap < 280) { zoom = 1; document.body.style.zoom = 1; }
    lastTap = now;
  }
}, {passive:true});
</script>
