// RENDER GROUP
function grpHTML(g) {
  var st = calcStandings(g);
  var played = g.matches.filter(function(m) { return m.s1!==null; }).length;
  var rows = st.map(function(t,i) {
    var qc = i===0?'q1':i===1?'q2':i===2?'q3':'';
    var gd = t.gd>=0?'+'+t.gd:t.gd;
    return '<tr class="'+qc+'"><td><div class="tn"><span class="fl">'+fl(t.name)+'</span>'+sn(t.name)+'</div></td>'
      +'<td class="pts-c">'+t.pts+'</td><td class="num-c">'+t.p+'</td>'
      +'<td class="num-c">'+gd+'</td><td class="num-c">'+t.gf+':'+t.ga+'</td></tr>';
  }).join('');
  var mrows = g.matches.map(function(m) {
    var sc = m.s1!==null
      ? '<span class="mscore">'+m.s1+'&ndash;'+m.s2+'</span>'
      : '<span class="mscore tbd">vs</span>';
    return '<div class="mrow"><span class="md">'+m.d+'</span>'
      +'<span class="mt1">'+fl(m.t1)+' '+sn(m.t1)+'</span>'+sc
      +'<span class="mt2">'+sn(m.t2)+' '+fl(m.t2)+'</span></div>';
  }).join('');
  return '<div class="grp"><div class="grp-hdr '+g.hc+'">GROUP '+g.id+'<small>'+played+'/6</small></div>'
    +'<table class="grp-tbl"><thead><tr><th>Team</th><th>Pts</th><th>P</th><th>GD</th><th>GF:GA</th></tr></thead>'
    +'<tbody>'+rows+'</tbody></table>'+mrows+'</div>';
}

