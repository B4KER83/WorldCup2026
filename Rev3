// STORAGE
var STORAGE_KEY = 'wc2026_scores';

function saveToStorage() {
  var data = {};
  GROUPS.forEach(function(g) {
    data[g.id] = g.matches.map(function(m) { return {s1:m.s1, s2:m.s2}; });
  });
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch(e) {}
}

function loadFromStorage() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    var data = JSON.parse(raw);
    GROUPS.forEach(function(g) {
      if (!data[g.id]) return;
      data[g.id].forEach(function(s, i) {
        if (g.matches[i] && s.s1 !== null && s.s2 !== null) {
          g.matches[i].s1 = s.s1;
          g.matches[i].s2 = s.s2;
        }
      });
    });
  } catch(e) {}
}

// STANDINGS
function calcStandings(g) {
  var s = {};
  g.teams.forEach(function(t) { s[t] = {p:0,w:0,d:0,l:0,gf:0,ga:0,gd:0,pts:0}; });
  g.matches.forEach(function(m) {
    if (m.s1 === null) return;
    var a = s[m.t1], b = s[m.t2];
    a.p++; b.p++;
    a.gf+=m.s1; a.ga+=m.s2; a.gd=a.gf-a.ga;
    b.gf+=m.s2; b.ga+=m.s1; b.gd=b.gf-b.ga;
    if (m.s1>m.s2) { a.w++; a.pts+=3; b.l++; }
    else if (m.s1<m.s2) { b.w++; b.pts+=3; a.l++; }
    else { a.d++; a.pts++; b.d++; b.pts++; }
  });
  return Object.keys(s).map(function(name) {
    return Object.assign({name:name}, s[name]);
  }).sort(function(x,y) {
    return (y.pts-x.pts) || (y.gd-x.gd) || (y.gf-x.gf);
  });
}

function getTopTwo(gid) {
  var g = GROUPS.filter(function(x) { return x.id===gid; })[0];
  var st = calcStandings(g);
  return { w:st[0].name, ru:st[1].name, third:st[2]?st[2].name:'?' };
}

function getBest3rd(groups) {
  // Get the projected 3rd place team from a list of group IDs
  // Returns the team currently in 3rd with best pts/gd/gf among those groups
  var candidates = [];
  groups.split('/').forEach(function(gid) {
    var g = GROUPS.filter(function(x) { return x.id === gid; })[0];
    var st = calcStandings(g);
    if (st[2]) {
      candidates.push({ name: st[2].name, pts: st[2].pts, gd: st[2].gd, gf: st[2].gf, gid: gid });
    }
  });
  candidates.sort(function(a,b) {
    return (b.pts-a.pts) || (b.gd-a.gd) || (b.gf-a.gf);
  });
  return candidates.length ? candidates[0].name + ' (3rd G' + candidates[0].gid + ')' : '3rd(' + groups + ')';
}

